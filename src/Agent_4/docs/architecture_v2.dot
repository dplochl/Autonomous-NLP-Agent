digraph V2 {
    graph [rankdir=TB, bgcolor=white, fontname="Helvetica",
           labelloc="t", label=<<B>V2 — Single-file Autonomous Multi-architecture LLM Agent</B>>,
           fontsize=22, dpi=160, nodesep=0.5, ranksep=0.7, compound=true];
    node [fontname="Helvetica", fontsize=12, shape=box, style="rounded,filled", color="#333333"];
    edge [fontname="Helvetica", fontsize=10, color="#555555"];

    trigger [label="python agent_fully_autonomous.py", shape=oval, fillcolor="#E0F0FF", color="#3a78b8"];

    subgraph cluster_loop {
        label=<<B>Per-iteration loop  (REQUIRED_ARCHITECTURES list)</B>>;
        style="rounded,dashed,filled"; color="#2f7a3a"; fillcolor="#eaf6ec";
        fontname="Helvetica-Bold"; fontsize=13; margin=14;

        pick   [label=<<B>1. pick next arch</B><br/><FONT POINT-SIZE="10">get_not_yet_attempted</FONT>>, fillcolor="#ffffff"];
        propose [label=<<B>2. LLM proposes full script</B><br/><FONT POINT-SIZE="10">FULL_SYSTEM prompt<br/>llm.propose()</FONT>>, fillcolor="#cfe0fa"];
        preflight [label=<<B>3. preflight_issues + syntax_check</B><br/><FONT POINT-SIZE="10">apply_light_autofixes<br/>(static checks before run)</FONT>>, fillcolor="#ffffff"];
        sandbox [label=<<B>4. sandbox.run_experiment</B><br/><FONT POINT-SIZE="10">dry-run + full run<br/>tail of stdout/stderr</FONT>>, fillcolor="#d6e8f5"];
        repair [label=<<B>5. request_repair</B><br/><FONT POINT-SIZE="10">LLM rewrite on failure</FONT>>, fillcolor="#fde2e2", color="#a83232"];
        analyze [label=<<B>6. analyze + memory.add</B><br/><FONT POINT-SIZE="10">success/fail · F1 · llm_analysis</FONT>>, fillcolor="#ffffff"];

        pick -> propose -> preflight -> sandbox -> analyze;
        sandbox -> repair [label="failure", color="#a83232", fontcolor="#a83232"];
        repair -> preflight [style=dashed, color="#a83232"];
    }

    plateau [label=<<B>plateau detector</B><br/><FONT POINT-SIZE="10">no improvement<br/>over PLATEAU_WINDOW iters</FONT>>, shape=note, fillcolor="#fff8d6", color="#c2a200"];
    memory [label=<<B>ExperimentMemory</B><br/><FONT POINT-SIZE="10">rolling list<br/>+ best() + leaderboard</FONT>>, fillcolor="#e6f4e8", color="#2f7a3a"];
    log    [label="experiment_log.json\n(flat list of trials)", shape=cylinder, fillcolor="#fffae0", color="#c2a200"];
    submission [label="submissions/*.csv", shape=cylinder, fillcolor="#e0f5e8", color="#2b8a3e"];

    trigger -> pick [lhead=cluster_loop];
    analyze -> memory [style=dashed, ltail=cluster_loop];
    memory -> propose [style=dotted, label="history summary", lhead=cluster_loop, constraint=false];
    analyze -> plateau [style=dashed, ltail=cluster_loop, constraint=false];
    plateau -> pick [style=dashed, label="stop if plateau", lhead=cluster_loop, constraint=false];
    analyze -> log [ltail=cluster_loop];
    sandbox -> submission [style=dashed, ltail=cluster_loop, constraint=false];
}
